# Yawmiyyati — Environment Variables
# Copy this file to .env.local and fill in all values

# ─── DATABASE ───────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/yawmiyyati"

# ─── AUTH ────────────────────────────────────────────────────
JWT_SECRET="your-very-long-random-secret-key-min-32-chars"
JWT_EXPIRES_IN="30d"

# ─── APP ─────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://yawmiyyati.com"
NEXT_PUBLIC_APP_NAME="Yawmiyyati"

# ─── PAYMOB ──────────────────────────────────────────────────
# Get from: https://accept.paymob.com → Settings → Account Info
PAYMOB_API_KEY="your-paymob-api-key"
# Get from: Settings → Developers → Secret Key
PAYMOB_SECRET_KEY="your-paymob-secret-key"
# Get from: Settings → Developers → HMAC Secret
PAYMOB_HMAC_SECRET="your-paymob-hmac-secret"
# Get from: Settings → Developers → Public Key
NEXT_PUBLIC_PAYMOB_PUBLIC_KEY="your-paymob-public-key"
# Get from: Accept → Integrations → Card Integration ID
PAYMOB_INTEGRATION_ID_CARD="your-card-integration-id"
# "production" or "staging"
PAYMOB_ENV="production"

# ─── EMAIL (RESEND) ───────────────────────────────────────────
RESEND_API_KEY="re_xxxxxxxxxxxxxxxx"
EMAIL_FROM="noreply@yawmiyyati.com"
EMAIL_FROM_NAME="Yawmiyyati"

# ─── STORAGE (Vercel Blob) ────────────────────────────────────
BLOB_READ_WRITE_TOKEN="vercel_blob_xxxxxxxxxxxxxxxx"

# ─── CRON ────────────────────────────────────────────────────
# Random secret to protect the /api/reminders/trigger endpoint
CRON_SECRET="your-random-cron-secret-string"
